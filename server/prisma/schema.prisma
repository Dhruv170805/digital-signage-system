// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model AppSettings {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String   // Store JSON or string values
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String
  role      String   @default("user") // admin, user
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  auditLogs AuditLog[]
}

model Screen {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  location     String?
  status       String        @default("offline")
  lastSeen     DateTime?
  ipAddress    String?
  macAddress   String?       @unique
  groupId      String?       @db.ObjectId
  group        ScreenGroup?  @relation(fields: [groupId], references: [id])
  schedules    Schedule[]
  tickerConfig String?       // JSON override for screen-specific ticker style
  updatedAt    DateTime      @updatedAt
}

model ScreenGroup {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  screens   Screen[]
  schedules Schedule[]
}

model Template {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  layoutJson  String   // Root layout properties
  frames      Frame[]
  schedules   Schedule[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Frame {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  templateId   String   @db.ObjectId
  template     Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name         String
  coordinateX  Float    // Percentage or Pixel
  coordinateY  Float
  width        Float
  height       Float
  zIndex       Int      @default(1)
  allowedTypes String?  // e.g. "image,video"
  schedules    Schedule[]
}

model Media {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  filename    String
  originalName String
  mimeType    String
  size        Int
  path        String
  status      String   @default("pending") // pending, approved, rejected
  uploadedBy  String?   @db.ObjectId
  schedules   Schedule[]
  createdAt   DateTime @default(now())
}

model Ticker {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  text         String
  speed        Int      @default(5)
  direction    String   @default("left")
  fontColor    String   @default("#FFFFFF")
  backgroundColor String @default("#000000")
  fontSize     Int      @default(24)
  priority     Int      @default(1) // Higher = override
  schedules    Schedule[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Schedule {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  priority    Int       @default(1)
  
  // Content (One of these should be set)
  mediaId     String?   @db.ObjectId
  media       Media?    @relation(fields: [mediaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  templateId  String?   @db.ObjectId
  template    Template? @relation(fields: [templateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tickerId    String?   @db.ObjectId
  ticker      Ticker?   @relation(fields: [tickerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  frameId     String?   @db.ObjectId
  frame       Frame?    @relation(fields: [frameId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Targets
  screenId    String?   @db.ObjectId
  screen      Screen?   @relation(fields: [screenId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  groupId     String?   @db.ObjectId
  group       ScreenGroup? @relation(fields: [groupId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Timing
  startDate   DateTime
  endDate     DateTime
  startTime   String?   // HH:mm
  endTime     String?   // HH:mm
  daysOfWeek  String?   // "1,2,3,4,5" (Monday=1)
  
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   String?  // JSON string
  timestamp DateTime @default(now())
}

model ErrorLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  message   String
  stack     String?
  context   String?  // JSON string
  timestamp DateTime @default(now())
}
