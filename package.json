{
  "name": "digital-signage-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm install --prefix server && npm install --prefix client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run install:all && npm run build --prefix client",
    "start": "NODE_ENV=production npm run start --prefix server",
    "qa-intelligence-system": "node qa-intelligence-system/orchestrator.js",
    "package:exe": "pkg . --targets node18-macos-x64,node18-linux-x64,node18-win-x64 --output dist/nexus-launcher",
    "package:win": "pkg . --targets node18-win-x64 --output dist/launcher-win.exe"
  },
  "bin": "launcher.js",
  "pkg": {
    "assets": [
      "server/**/*",
      "client/dist/**/*",
      "node_modules/**/*"
    ],
    "scripts": [
      "server/src/**/*.js"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "pkg": "^5.8.1",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "open": "^11.0.0"
  }
}
